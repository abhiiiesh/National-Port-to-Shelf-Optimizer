# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=port_to_shelf
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Kafka Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=port-to-shelf-optimizer

# Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=3600

# ULIP Integration
ULIP_API_URL=https://api.ulip.gov.in
ULIP_CLIENT_ID=your-client-id
ULIP_CLIENT_SECRET=your-client-secret
ULIP_AUTH_URL=https://auth.ulip.gov.in/oauth2/token

# Service Ports
API_GATEWAY_PORT=3000
AUTH_SERVICE_PORT=3001
VESSEL_TRACKING_PORT=3002
CONTAINER_TRACKING_PORT=3003
AI_PREDICTION_PORT=3004
AUCTION_PORT=3005
SLOT_MANAGEMENT_PORT=3006
ULIP_INTEGRATION_PORT=3007

# Environment
NODE_ENV=development
LOG_LEVEL=info
